{
  "name": "@ada/simulated-world-ui",
  "version": "1.0.0",
  "description": "Web UI dashboard for SimulatedWorld observability",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev -p 3001\" \"tsx server.ts\"",
    "build": "next build && tsc server.ts --outDir dist --module commonjs",
    "start": "concurrently \"next start -p 3001\" \"node dist/server.js\"",
    "lint": "next lint"
  },
  "dependencies": {
    "@shadcn/ui": "^0.0.4",
    "baseui": "^18.2.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.294.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.14.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/ws": "^8.5.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.2.0"
  }
}
